# InsForge configuration (REQUIRED)
# Get these values from your InsForge project dashboard.
# For local development, copy this file to .env.local and fill in the values below.
NEXT_PUBLIC_INSFORGE_URL=https://txv86efe.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=ik_7e23032539c2dc64d5d27ca29d07b928

# InsForge server-side API key (for privileged server operations, never expose in browser)
INSFORGE_API_KEY=

# Dominio público de la aplicación, por ejemplo https://fabrick.cl
NEXT_PUBLIC_APP_URL=localhost:3000

# Credenciales de Mercado Pago
# Access token del servidor (mantener secreto — nunca exponer en el navegador)
MERCADO_PAGO_ACCESS_TOKEN=
MERCADOPAGO_ACCESS_TOKEN=
MP_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADOPAGO_WEBHOOK_SECRET=

# Clave pública de MercadoPago para el SDK de cliente (tokenización de tarjetas)
# Obtener en: https://www.mercadopago.cl/settings/account/credentials
# En producción usa la clave "productiva"; en pruebas usa la clave "sandbox" (comienza con TEST-)
# Aceptamos múltiples nombres para que no te bloquees por mayúsculas/guiones bajos:
# NEXT_PUBLIC_MP_PUBLIC_KEY (recomendado: se inlinea en el bundle del cliente)
# o, si prefieres no inlinearla en el bundle, usa una de las variantes server-only
# (la app la sirve al navegador vía /api/payments/mp-status):
# MP_PUBLIC_KEY / MERCADO_PAGO_PUBLIC_KEY / MERCADOPAGO_PUBLIC_KEY
NEXT_PUBLIC_MP_PUBLIC_KEY=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Secret used to sign the admin session cookie (HMAC-SHA256).
# REQUIRED in production — the app will fail to start the admin session otherwise.
# Generate with: openssl rand -base64 48
# Rotating this value invalidates all active admin sessions.
ADMIN_SESSION_SECRET=

# Admin account setup (optional overrides – defaults shown)
# ADMIN_EMAIL=feduardomsz@gmail.com
# ADMIN_INITIAL_PASSWORD=<your-initial-password>

# Mercado Libre — Importador de productos (admin)
# Token OAuth de la API pública de Mercado Libre. Sólo es necesario
# cuando el endpoint /items/{id} responde HTTP 403 desde la IP del
# servidor (típico en Vercel/AWS). Genera un token corto (6h) en:
#   https://developers.mercadolibre.com/ → Aplicaciones → Probar
# Si está vacío el importador igual intentará el fallback /items?ids=…
MERCADOLIBRE_ACCESS_TOKEN=

# Búsqueda universal de productos similares (Google Programmable Search / CSE)
# Sirve al endpoint /api/admin/productos/similar para sugerir productos
# desde toda la web (no sólo Mercado Libre). Si quedan vacíos, la app
# cae automáticamente a Google Shopping scrape y luego a DuckDuckGo HTML.
# 1) Crea un motor en https://programmablesearchengine.google.com → "Search the entire web"
# 2) Copia el "Search engine ID" (cx) abajo.
# 3) Crea una API key en https://console.cloud.google.com/apis/credentials
#    y habilita "Custom Search API" para ese proyecto.
GOOGLE_CSE_CX=82f484103127c49b5
GOOGLE_CSE_KEY=

# Jina Reader (r.jina.ai) — fallback para tiendas con WAF agresivo
# Cuando una URL devuelve 403/Cloudflare challenge, el importador
# intenta como último recurso https://r.jina.ai/<url> que renderiza
# la página con un navegador headless real. La free tier (sin key)
# es ~20 RPM y se agota rápido. Con esta key el límite sube
# considerablemente. Generala gratis en https://jina.ai/reader
JINA_API_KEY=

# Meta Ads / Graph API
META_ACCESS_TOKEN=
META_API_VERSION=v25.0
META_AD_ACCOUNT_ID=
META_ACCOUNT_ID=

# WhatsApp de contacto operativo (sólo dígitos, sin "+" ni espacios).
# Si no se define, la app usa el número productivo 56930121625 como fallback.
NEXT_PUBLIC_WHATSAPP_NUMBER=56930121625

# Cloudinary (optional — required only if using Cloudinary for media storage)
# Get these from: cloudinary.com > Settings > API Keys
# Store them in the Admin panel under Configuración > Integraciones > Cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Sentry (observability) — optional in development.
# The SDK only reports events when NODE_ENV === 'production' AND a DSN is set,
# so leaving these blank locally is safe and keeps the dashboard clean.
# Public DSN (inlined into the client bundle):
NEXT_PUBLIC_SENTRY_DSN=
# Override the reported environment name (defaults to "production"):
# NEXT_PUBLIC_SENTRY_ENV=production
# Build-time only — required in CI/Vercel to upload source maps; not used at runtime.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
