# InsForge configuration (REQUIRED)
# Get these values from your InsForge project dashboard.
# For local development, copy this file to .env.local and fill in the values below.
NEXT_PUBLIC_INSFORGE_URL=https://YOUR_PROJECT_ID.YOUR_REGION.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=ik_YOUR_ANON_KEY_HERE

# InsForge server-side API key (for privileged server operations, never expose in browser)
INSFORGE_API_KEY=

# Dominio público de la aplicación, por ejemplo https://fabrick.cl
NEXT_PUBLIC_APP_URL=

# Credenciales de Mercado Pago
# Access token del servidor (mantener secreto — nunca exponer en el navegador)
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# Clave pública de MercadoPago para el SDK de cliente (tokenización de tarjetas)
# Obtener en: https://www.mercadopago.cl/settings/account/credentials
# En producción usa la clave "productiva"; en pruebas usa la clave "sandbox" (comienza con TEST-)
NEXT_PUBLIC_MP_PUBLIC_KEY=

# Secret used to sign the admin session cookie (HMAC-SHA256).
# REQUIRED in production — the app will fail to start the admin session otherwise.
# Generate with: openssl rand -base64 48
# Rotating this value invalidates all active admin sessions.
ADMIN_SESSION_SECRET=

# Admin account setup (optional overrides – defaults shown)
# ADMIN_EMAIL=feduardomsz@gmail.com
# ADMIN_INITIAL_PASSWORD=<your-initial-password>
